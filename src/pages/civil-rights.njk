  </div>
</section>

{# ============================================
   THE VOTE — KEY TO THE PARTY SWITCH
   ============================================ #}
<section class="chapter chapter--muted" id="chapter-vote" data-chapter="The Vote">
  <div class="chapter__inner">
    <div class="chapter__content chapter__content--center reveal">
      <span class="eyebrow">The Critical Evidence</span>
      <h2 class="headline-chapter">{{ civilRightsData.civilRightsActVote.headline }}</h2>
      <p class="subheadline">{{ civilRightsData.civilRightsActVote.explanation }}</p>
    </div>
    <div class="chapter__content chapter__content--wide">
      <div class="vote-breakdown-grid">
        <div class="vote-breakdown reveal">
          <h3 class="vote-breakdown__chamber">Senate Vote — Civil Rights Act (1964)</h3>
          <div class="vote-breakdown__rows">
            <div class="vote-breakdown__row">
              <span class="vote-breakdown__group">Democrats (total)</span>
              <span class="vote-breakdown__result">{{ civilRightsData.civilRightsActVote.senate.democratsTotal }}</span>
            </div>
            <div class="vote-breakdown__row">
              <span class="vote-breakdown__group">Republicans (total)</span>
              <span class="vote-breakdown__result">{{ civilRightsData.civilRightsActVote.senate.republicansTotal }}</span>
            </div>
            <div class="vote-breakdown__row vote-breakdown__row--divider"></div>
            <div class="vote-breakdown__row vote-breakdown__row--key">
              <span class="vote-breakdown__group">Northern Democrats</span>
              <span class="vote-breakdown__result vote-breakdown__result--yes">{{ civilRightsData.civilRightsActVote.senate.northernDemocrats }}</span>
            </div>
            <div class="vote-breakdown__row vote-breakdown__row--key">
              <span class="vote-breakdown__group">Southern Democrats</span>
              <span class="vote-breakdown__result vote-breakdown__result--no">{{ civilRightsData.civilRightsActVote.senate.southernDemocrats }}</span>
            </div>
          </div>
          <p class="vote-breakdown__note">{{ civilRightsData.civilRightsActVote.senate.note }}</p>
        </div>
        <div class="vote-breakdown reveal">
          <h3 class="vote-breakdown__chamber">House Vote — Civil Rights Act (1964)</h3>
          <div class="vote-breakdown__rows">
            <div class="vote-breakdown__row">
              <span class="vote-breakdown__group">Democrats (total)</span>
              <span class="vote-breakdown__result">{{ civilRightsData.civilRightsActVote.house.democratsTotal }}</span>
            </div>
            <div class="vote-breakdown__row">
              <span class="vote-breakdown__group">Republicans (total)</span>
              <span class="vote-breakdown__result">{{ civilRightsData.civilRightsActVote.house.republicansTotal }}</span>
            </div>
            <div class="vote-breakdown__row vote-breakdown__row--divider"></div>
            <div class="vote-breakdown__row vote-breakdown__row--key">
              <span class="vote-breakdown__group">Northern Democrats</span>
              <span class="vote-breakdown__result vote-breakdown__result--yes">{{ civilRightsData.civilRightsActVote.house.northernDemocrats }}</span>
            </div>
            <div class="vote-breakdown__row vote-breakdown__row--key">
              <span class="vote-breakdown__group">Southern Democrats</span>
              <span class="vote-breakdown__result vote-breakdown__result--no">{{ civilRightsData.civilRightsActVote.house.southernDemocrats }}</span>
            </div>
          </div>
          <p class="vote-breakdown__note">{{ civilRightsData.civilRightsActVote.house.note }}</p>
        </div>
      </div>
      <div class="chapter__content chapter__content--narrow reveal" style="margin-top: var(--space-md);">
        <a href="{{ civilRightsData.civilRightsActVote.sourceUrl }}" target="_blank" rel="noopener noreferrer" style="color: var(--accent-gold); font-size: 0.9rem;">{{ civilRightsData.civilRightsActVote.sourceNote }} &rarr;</a>
      </div>
    </div>
  </div>
</section>

