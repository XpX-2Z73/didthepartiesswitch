          <span class="cr-stat__figure">{{ stat.figure }}</span>
          <span class="cr-stat__label">{{ stat.label }}</span>
          <span class="cr-stat__detail">{{ stat.detail }}</span>
          <span class="cr-stat__source">{{ stat.source }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# ============================================
