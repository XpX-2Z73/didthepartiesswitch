<section class="chapter chapter--dark" id="chapter-timeline" data-chapter="Timeline">
  <div class="chapter__inner">
    <div class="chapter__content chapter__content--center reveal">
      <span class="eyebrow">1954 – 1968</span>
      <h2 class="headline-chapter">Fourteen Years of Strategy</h2>
    </div>
    <div class="chapter__content chapter__content--narrow">
      <div class="cr-timeline">
        {% for event in civilRightsData.timeline %}
