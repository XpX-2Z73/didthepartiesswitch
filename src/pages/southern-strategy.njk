          <div class="ss-election__year">{{ election.year }}</div>
          <div class="ss-election__body">
            <p class="ss-election__result">{{ election.southernResult }}</p>
            <p class="ss-election__note">{{ election.note }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="callout callout--dark reveal" style="margin-top: var(--space-md);">
        <a href="{{ southernStrategyData.voterShift.sourceUrl }}" target="_blank" rel="noopener noreferrer" style="color: var(--accent-gold); font-size: 0.9rem;">{{ southernStrategyData.voterShift.sourceNote }} &rarr;</a>
      </div>
    </div>
  </div>
</section>

