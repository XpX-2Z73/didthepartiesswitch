{# ============================================
   BY STATE
   ============================================ #}
<section class="chapter chapter--muted" id="chapter-states" data-chapter="By State">
  <div class="chapter__inner">
    <div class="chapter__content chapter__content--center reveal">
      <span class="eyebrow">1877 – 1950</span>
      <h2 class="headline-chapter">Southern States — Documented Lynchings</h2>
      <p class="subheadline">EJI count, 12 states. Not the national total.</p>
    </div>
    <div class="chapter__content chapter__content--wide">
      <div class="lynching-states-grid">
        {% for state in lynchingData.byState %}
        <div class="lynching-state reveal">
          <div class="lynching-state__bar-wrap">
            <div class="lynching-state__bar" style="width: {{ (state.count / 654 * 100) | round }}%"></div>
          </div>
          <div class="lynching-state__info">
            <span class="lynching-state__name">{{ state.state }}</span>
            <span class="lynching-state__count">{{ state.count }}</span>
          </div>
          {% if state.note %}<span class="lynching-state__note">{{ state.note }}</span>{% endif %}
        </div>
        {% endfor %}
      </div>
      <p class="caption" style="text-align: center; margin-top: 1.5rem;">
        Source: Equal Justice Initiative, <em>Lynching in America</em> (2015). Data covers 12 Southern states; national totals are higher.
      </p>
    </div>
  </div>
</section>

