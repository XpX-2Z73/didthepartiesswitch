{# State Election Table - pre-rendered #}
<div class="data-table-wrapper">
  <table id="election-table" class="data-table" aria-describedby="election-table-note">
    <caption class="sr-only">
      2024 presidential winners and voting access notes for states that seceded in 1860-61
    </caption>
    <colgroup>
      <col style="width: 13%">
      <col style="width: 10%">
      <col style="width: 17%">
      <col style="width: 60%">
    </colgroup>
    <thead>
      <tr>
        <th scope="col">State</th>
        <th scope="col">Seceded</th>
        <th scope="col">2024 Winner</th>
        <th scope="col">Access Notes</th>
      </tr>
    </thead>
    <tbody>
      {% for state in states %}
        <tr>
          <td>{{ state.state }}</td>
          <td>{{ "Yes" if state.seceded else "No" }}</td>
          <td>{{ state.winner2024 }}</td>
          <td>{{ state.notes }}</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
